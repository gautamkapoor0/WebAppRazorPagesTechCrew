@page
@model WebAppRazorPagesTechCrew.Pages.LoginModel
@{
}


<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


<body class="bg-light">

    <div class="container">
        <div class="row justify-content-center mt-5">

            <div class="col-md-5">

                <div class="card shadow-lg">
                    <div class="card-header bg-primary text-white text-center">
                        <h3>Login</h3>
                    </div>

                    <div class="card-body">

                        <form method="post">

                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" placeholder="Enter Email" asp-for="_obj.Email">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" class="form-control" placeholder="Enter Password" asp-for="_obj.Password">
                            </div>

                            <div class="d-grid">

                                <input type="submit" value="login" class="btn btn-primary" />
                                @TempData["errormsg"]
                            </div>
                            <a asp-page="Register">dont have Account Click here</a>
                        </form>

                    </div>
                </div>

            </div>

        </div>
    </div>
</body>