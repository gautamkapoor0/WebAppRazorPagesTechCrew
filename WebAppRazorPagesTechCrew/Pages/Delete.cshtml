@page
@model WebAppRazorPagesTechCrew.Pages.DeleteModel
@{
}


<h2>Delete User</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this user?
</div>



<div class="mb-3">
    <strong>Name :</strong> @Model._obj.UserName
</div>

<div class="mb-3">
    <strong>Email :</strong> @Model._obj.Email
</div>

<form method="post">

    <input type="hidden" asp-for="_obj.ID" />

    <button type="submit"
            class="btn btn-danger">
        Delete
    </button>

    <a asp-page="/UsersList"
       class="btn btn-secondary">
        Cancel
    </a>

</form>